# POC Data Agent VPS — Variáveis de ambiente
# Copie para infra/compose-core/.env e ajuste.
# NUNCA commitar o .env real — apenas este .env.example vai ao Git.
#
# Gerar FERNET_KEY:
#   python3 -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# Gerar SECRET_KEY:
#   openssl rand -hex 32

POSTGRES_USER=airflow
POSTGRES_PASSWORD=TROQUE_MIN_8_CHARS
POSTGRES_DB=airflow

AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=GERE_FERNET_KEY_BASE64_32_BYTES
AIRFLOW__WEBSERVER__SECRET_KEY=GERE_SECRET_KEY_HEX_32
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__LOGGING__LOGGING_LEVEL=WARNING

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=TROQUE_MIN_8_CHARS
MINIO_ENDPOINT=http://minio:9000

CLICKHOUSE_DB=poc_dw
CLICKHOUSE_USER=poc_user
CLICKHOUSE_PASSWORD=TROQUE_SENHA

FASTAPI_SECRET_KEY=GERE_SECRET_KEY_HEX_32
DOMAIN=localhost
QDRANT_API_KEY=TROQUE_QDRANT_KEY
OLLAMA_MODEL=qwen2.5:1.5b
