<clickhouse>
  <!-- Usuário poc_user definido via config — funciona mesmo com volume existente.
       Evita o "Skipping initialization" que ocorre quando o data directory já existe. -->
  <users>
    <poc_user>
      <password>click2024</password>
      <networks>
        <ip>::/0</ip>
      </networks>
      <profile>default</profile>
      <quota>default</quota>
      <access_management>1</access_management>
    </poc_user>
    <default>
      <password></password>
      <networks>
        <ip>127.0.0.1</ip>
        <ip>::1</ip>
      </networks>
      <profile>default</profile>
      <quota>default</quota>
    </default>
  </users>
</clickhouse>
